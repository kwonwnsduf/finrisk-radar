# Application ports
BACKEND_PORT=8080
FRONTEND_PORT=3000

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=finrisk
POSTGRES_USER=finrisk
POSTGRES_PASSWORD=change-me-postgres

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

# Kafka and ZooKeeper
ZOOKEEPER_PORT=2181
KAFKA_HOST_PORT=29092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Frontend backend proxy
NEXT_PUBLIC_API_BASE_URL=/backend-api
NEXT_PUBLIC_OAUTH_BASE_URL=http://localhost:8080
BACKEND_API_URL=http://backend:8080

# JWT (Base64-encoded random key of at least 32 bytes)
JWT_SECRET=replace-with-base64-encoded-32-byte-secret

# Google OAuth2 (use credentials from Google Cloud Console)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
OAUTH_FRONTEND_REDIRECT_URI=http://localhost:3000/login
OAUTH_CODE_TTL=180s

# AWS S3 raw market data storage
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=replace-with-aws-access-key
AWS_SECRET_KEY=replace-with-aws-secret-key
AWS_S3_BUCKET=replace-with-s3-bucket

# Day 11 document collection
NAVER_NEWS_BASE_URL=https://naverapihub.apigw.ntruss.com
NAVER_CLIENT_ID=replace-with-naver-client-id
NAVER_CLIENT_SECRET=replace-with-naver-client-secret
DOCUMENT_COLLECTION_SCHEDULER_ENABLED=false
DOCUMENT_COLLECTION_SCHEDULER_CRON=0 0 * * * *
DOCUMENT_RECALCULATION_MAX_ATTEMPTS=5

# Day 12 RAG embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_BATCH_SIZE=32
OPENAI_LLM_MODEL=gpt-5.6-terra
OPENAI_LLM_CONNECT_TIMEOUT=5s
OPENAI_LLM_READ_TIMEOUT=60s
OPENAI_LLM_MAX_OUTPUT_TOKENS=2000
OPENAI_LLM_MAX_CONTEXT_CHARACTERS=24000

# Monitoring
SEED_REIT_RISK_SCENARIOS_ENABLED=false

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
